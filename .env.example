# ---------------------------------------------------------------------------
# ai-image-gen environment. Copy to .env and fill in. docker-compose reads this
# file; the defaults below match the local docker-compose stack (postgres + minio).
# ---------------------------------------------------------------------------

# --- Database (Postgres) ---------------------------------------------------
# Runtime (pooled) connection used by the Prisma Client adapter.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/aiimagegen?schema=public
# Direct (non-pooled) connection used by Prisma Migrate / CLI. Same as above for
# local dev; in prod point at the RDS direct endpoint.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/aiimagegen?schema=public

# --- AI engines ------------------------------------------------------------
# Provider mode. "fixtures" runs offline at zero cost (canned clarifying
# questions + sharp-generated placeholder images); "live" uses the real engines.
# AI_PROVIDER is the default for both engines; GEMINI_PROVIDER / CLAUDE_PROVIDER
# override per engine — e.g. test real nano-banana while Claude stays free:
#   AI_PROVIDER=fixtures
#   GEMINI_PROVIDER=live   (with GEMINI_API_KEY below)
AI_PROVIDER=fixtures
# GEMINI_PROVIDER=live
# CLAUDE_PROVIDER=live

# Anthropic API key for the Claude Agent SDK (refinement engine). Only needed
# when the Claude engine is live.
ANTHROPIC_API_KEY=
# Google Gemini API key (creative engine). The @google/genai SDK also accepts GOOGLE_API_KEY.
GEMINI_API_KEY=

# Model ids (override to pin a version). nano-banana = Gemini flash image.
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image
GEMINI_TEXT_MODEL=gemini-2.5-flash
CLAUDE_MODEL=claude-sonnet-4-6

# How many candidates the CHOOSING step generates. Lower (e.g. 1) while testing
# to save tokens; default 3.
CANDIDATE_COUNT=3

# Max clarifying questions asked about a vague prompt before generating. Default 5.
CLARIFY_MAX_QUESTIONS=5

# --- Object storage (S3 / MinIO) -------------------------------------------
S3_BUCKET=ai-image-gen
S3_REGION=us-east-1
# Local dev points at MinIO. Leave blank in prod to use real AWS S3.
S3_ENDPOINT=http://localhost:9000
# Path-style addressing is required for MinIO; leave true locally, false/blank on AWS.
S3_FORCE_PATH_STYLE=true
# Static creds for MinIO local dev. In prod prefer an App Runner instance IAM
# role and leave these blank (the AWS SDK picks up the role automatically).
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# --- App -------------------------------------------------------------------
# Public base URL (used when building absolute links if needed).
NEXT_PUBLIC_BASE_URL=http://localhost:3000
