// An async unit of AI work (Gemini generation/edit or Claude refinement). The
// in-process runner (src/logic/jobProcessor.ts) claims queued jobs and runs
// them; the client polls the job until it reaches `done` or `error`.
model Job {
  id        String @id @default(cuid(2))
  projectId String

  type   JobType
  status JobStatus @default(queued)

  // Inputs for the job (prompt, instruction, sourceImageId, answers, …).
  payload Json @default("{}")

  // Image rows produced by the job (candidate ids, refined image id, …).
  resultImageIds String[] @default([])

  error String?

  // Structured Gemini finish/block reason code for an AI failure (e.g.
  // "IMAGE_RECITATION"), surfaced to the user as a friendly "AI error".
  failureReason String?

  // Usage for a job that consumed tokens but produced no Image row (e.g. an
  // image call that returned no image). Successful jobs record usage on the
  // Image(s) they create instead, so this is only set on such failures.
  model        String?
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?

  createdAt  DateTime  @default(now()) @db.Timestamptz(6)
  startedAt  DateTime? @db.Timestamptz(6)
  finishedAt DateTime? @db.Timestamptz(6)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([projectId, createdAt])
}
